      SELECT "s"."Key" AS "ProductName", COALESCE(SUM("s"."Quantite"), 0) AS "TotalSold", COALESCE(ef_sum("s"."MontantTTC"), '0.0') AS "TotalRevenue"
      FROM (
          SELECT "l"."MontantTTC", "l"."Quantite", "p0"."Nom" AS "Key"
          FROM "LigneFactures" AS "l"
          INNER JOIN (
              SELECT "f"."Id", "f"."IsDeleted", "f"."Statut"
              FROM "Factures" AS "f"
              WHERE NOT ("f"."IsDeleted")
          ) AS "f0" ON "l"."FactureId" = "f0"."Id"
          INNER JOIN (
              SELECT "p"."Id", "p"."Nom"
              FROM "Produits" AS "p"
              WHERE NOT ("p"."IsDeleted")
          ) AS "p0" ON "l"."ProduitId" = "p0"."Id"
          WHERE NOT ("l"."IsDeleted") AND NOT ("l"."IsDeleted") AND NOT ("f0"."IsDeleted") AND "f0"."Statut" IN ('Validée', 'Payée')
      ) AS "s"
      GROUP BY "s"."Key"
      ORDER BY COALESCE(ef_sum("s"."MontantTTC"), '0.0') COLLATE EF_DECIMAL DESC
      LIMIT @p
