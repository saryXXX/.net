<div class="top-row ps-3 navbar navbar-dark">
    @inject IAuthService AuthService
    @inject NavigationManager NavigationManager

    <div class="container-fluid py-2">
        <a class="navbar-brand d-flex align-items-center justify-content-center w-100" href="">
            <img src="logo-darkmode.png" alt="Factun Logo" style="height: 50px; width: auto;" />
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column mt-3">
        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link rounded-pill" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span>
                <span class="nav-text">Home</span>
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link rounded-pill" href="clients">
                <span class="bi bi-people-fill" aria-hidden="true"></span>
                <span class="nav-text">Clients</span>
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link rounded-pill" href="products">
                <span class="bi bi-box-seam-fill" aria-hidden="true"></span>
                <span class="nav-text">Products</span>
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link rounded-pill" href="invoices">
                <span class="bi bi-receipt-cutoff" aria-hidden="true"></span>
                <span class="nav-text">Invoices</span>
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link rounded-pill" href="stock">
                <span class="bi bi-archive-fill" aria-hidden="true"></span>
                <span class="nav-text">Stock Levels</span>
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link rounded-pill" href="analytics">
                <span class="bi bi-pie-chart-fill" aria-hidden="true"></span>
                <span class="nav-text">Analytics</span>
            </NavLink>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 mt-4 mb-2">
                    <button class="nav-link rounded-pill border-0 bg-transparent w-100 text-start text-danger logout-btn" @onclick="Logout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span>
                        <span class="nav-text">Logout</span>
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

<style>
    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .nav-link {
        color: rgba(255, 255, 255, 0.6);
        transition: all 0.2s ease;
        padding: 0.75rem 1.25rem !important;
        display: flex !important;
        align-items: center !important;
    }

    .nav-link:hover {
        background-color: rgba(36, 152, 99, 0.1);
        color: #249863;
    }

    .nav-link.active {
        background-color: #249863 !important;
        color: white !important;
        box-shadow: 0 4px 12px rgba(36, 152, 99, 0.2);
    }

    .nav-link i, .nav-link span.bi {
        margin-right: 12px;
        margin-bottom: 0;
        font-size: 1.1rem;
        display: inline-flex;
        align-items: center;
    }

    .nav-text {
        font-weight: 500;
    }

    .logout-btn {
        margin-top: 2rem;
        border: 1px solid rgba(220, 53, 69, 0.2) !important;
    }

    .logout-btn:hover {
        background-color: rgba(220, 53, 69, 0.1) !important;
        color: #dc3545 !important;
    }
</style>


@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        NavigationManager.NavigateTo("login");
    }
}
