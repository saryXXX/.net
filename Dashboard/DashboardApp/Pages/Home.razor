@page "/"
@attribute [Authorize]
@using DashboardApp.Services
@using Dashboard.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Dashboard - Sary System</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Executive Overview</h1>
            <p class="text-muted small mb-0">Welcome back! Here is what's happening today.</p>
        </div>
        <div class="text-muted small">
            <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dd MMMM yyyy")
        </div>
    </div>

    @if (stats == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Summary Stats -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 card-ca h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-white text-primary rounded-3 shadow-sm">
                            <i class="bi bi-currency-dollar"></i>
                        </div>
                        <span class="badge bg-success-subtle text-success rounded-pill">+12.5%</span>
                    </div>
                    <h6 class="text-uppercase small fw-bold text-muted mb-1">Total Revenue</h6>
                    <h3 class="fw-bold mb-0">@stats.TotalCA.ToString("N3") <small class="fs-6 fw-normal">TND</small></h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-light text-success rounded-3">
                            <i class="bi bi-receipt"></i>
                        </div>
                    </div>
                    <h6 class="text-uppercase small fw-bold text-muted mb-1">Invoices</h6>
                    <h3 class="fw-bold mb-0">@stats.TotalFactures</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-light text-warning rounded-3">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        @if (stats.ProduitsEnAlerte > 0)
                        {
                            <span class="badge bg-danger rounded-pill">@stats.ProduitsEnAlerte Alerts</span>
                        }
                    </div>
                    <h6 class="text-uppercase small fw-bold text-muted mb-1">Low Stock Items</h6>
                    <h3 class="fw-bold mb-0">@stats.ProduitsEnAlerte</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-info text-white">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-white bg-opacity-25 text-white rounded-3">
                            <i class="bi bi-people"></i>
                        </div>
                    </div>
                    <h6 class="text-uppercase small fw-bold text-white text-opacity-75 mb-1">Total Clients</h6>
                    <h3 class="fw-bold mb-0">@totalClients</h3>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Quick Actions -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <h5 class="fw-bold mb-4">Quick Actions</h5>
                    <div class="d-grid gap-3">
                        <button class="btn btn-outline-brand-green rounded-4 p-3 text-start d-flex align-items-center" @onclick='() => Navigation.NavigateTo("/invoices/new")'>
                            <div class="icon-box bg-brand-green-subtle text-brand-green me-3 rounded-3">
                                <i class="bi bi-file-earmark-plus"></i>
                            </div>
                            <div>
                                <div class="fw-bold">New Invoice</div>
                                <div class="x-small text-muted">Generate a new customer bill</div>
                            </div>
                        </button>
                        <button class="btn btn-outline-brand-green rounded-4 p-3 text-start d-flex align-items-center" @onclick='() => Navigation.NavigateTo("/products")'>
                            <div class="icon-box bg-brand-green-subtle text-brand-green me-3 rounded-3">
                                <i class="bi bi-plus-circle"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Add Product</div>
                                <div class="x-small text-muted">Register a new item in catalog</div>
                            </div>
                        </button>
                        <button class="btn btn-outline-brand-green rounded-4 p-3 text-start d-flex align-items-center" @onclick='() => Navigation.NavigateTo("/clients")'>
                            <div class="icon-box bg-brand-green-subtle text-brand-green me-3 rounded-3">
                                <i class="bi bi-person-plus"></i>
                            </div>
                            <div>
                                <div class="fw-bold">New Client</div>
                                <div class="x-small text-muted">Onboard a new customer</div>
                            </div>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Revenue Evolution Chart -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white border-0 py-3 px-4">
                        <h5 class="fw-bold mb-0">Revenue Evolution (CA)</h5>
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="ChartDataDto" XAxisType="XAxisType.Category">
                            <ApexPointSeries TItem="ChartDataDto" 
                                           Items="stats.TurnoverHistory" 
                                           Name="Revenue" 
                                           SeriesType="SeriesType.Area"
                                           XValue="@(e => e.Label)" 
                                           YValue="@(e => e.Value)" 
                                           Color="#249863" />
                        </ApexChart>
                    </div>
                </div>
            </div>

            <!-- VAT Distribution -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white border-0 py-3 px-4">
                        <h5 class="fw-bold mb-0">VAT Distribution</h5>
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        @if (fiscalSummary?.TvaDetails?.Any() == true)
                        {
                            <ApexChart TItem="TvaRateDto">
                                <ApexPointSeries TItem="TvaRateDto" 
                                                Items="fiscalSummary.TvaDetails" 
                                                Name="VAT Amount" 
                                                SeriesType="SeriesType.Donut" 
                                                XValue="@(e => $"{e.Rate}%")" 
                                                YValue="@(e => e.TotalTva)" />
                            </ApexChart>
                        }
                        else
                        {
                            <p class="text-muted small">No tax data available</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Top Products Table -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <div class="card-header bg-white border-0 py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">Top Performing Products</h5>
                        <button class="btn btn-sm btn-light rounded-pill px-3" @onclick='() => Navigation.NavigateTo("/products")'>View Catalog</button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-dark text-white x-small text-uppercase">
                                    <tr>
                                        <th class="ps-4 py-3">Product Name</th>
                                        <th class="text-end">Sold</th>
                                        <th class="text-end pe-4">Revenue</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in stats.TopProducts.Take(5))
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="fw-bold">@p.ProductName</div>
                                            </td>
                                            <td class="text-end">@p.TotalSold</td>
                                            <td class="text-end pe-4 fw-bold text-brand-green">@p.TotalRevenue.ToString("N3") TND</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Inventory Status -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white border-0 py-3 px-4">
                        <h5 class="fw-bold mb-0">Inventory Health</h5>
                    </div>
                    <div class="card-body">
                        @if (inventorySummary?.StatusBreakdown?.Any() == true)
                        {
                            <ApexChart TItem="StockStatusDto">
                                <ApexPointSeries TItem="StockStatusDto" 
                                                Items="inventorySummary.StatusBreakdown" 
                                                Name="Items" 
                                                SeriesType="SeriesType.Bar" 
                                                XValue="@(e => e.Status)" 
                                                YValue="@(e => (decimal)e.Count)"
                                                Color="#111111" />
                            </ApexChart>
                        }
                    </div>
                </div>
            </div>
        </div>

    }
</div>

<style>
    .icon-box {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }
    .card-ca { background: #111111; color: white; }
    .card-ca .text-muted { color: rgba(255, 255, 255, 0.6) !important; }
    .x-small { font-size: 0.75rem; }
    .bg-success-subtle { background-color: #dcfce7; color: #16a34a; }
    .bg-brand-green-subtle { background-color: rgba(36, 152, 99, 0.1); }
    .text-brand-green { color: #249863; }
    .btn-outline-brand-green {
        border-color: rgba(36, 152, 99, 0.2);
        color: #333;
    }
    .btn-outline-brand-green:hover {
        border-color: #249863;
        background-color: rgba(36, 152, 99, 0.05);
        color: #111;
    }
</style>


@code {
    private DashboardStatsDto? stats;
    private FiscalSummaryDto? fiscalSummary;
    private InventorySummaryDto? inventorySummary;
    private int totalClients;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var statsTask = Http.GetFromJsonAsync<DashboardStatsDto>("api/analytics/dashboard");
            var fiscalTask = Http.GetFromJsonAsync<FiscalSummaryDto>("api/analytics/fiscal");
            var inventoryTask = Http.GetFromJsonAsync<InventorySummaryDto>("api/analytics/inventory");
            var clientsTask = Http.GetFromJsonAsync<List<ClientDto>>("api/clients");

            await Task.WhenAll(statsTask, fiscalTask, inventoryTask, clientsTask);

            stats = await statsTask;
            fiscalSummary = await fiscalTask;
            inventorySummary = await inventoryTask;
            totalClients = (await clientsTask)?.Count ?? 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching dashboard data: {ex.Message}");
            stats = new DashboardStatsDto() { TurnoverHistory = new(), TopProducts = new() };
            fiscalSummary = new FiscalSummaryDto() { TvaDetails = new() };
            inventorySummary = new InventorySummaryDto() { StatusBreakdown = new() };
        }
    }
}

