@page "/clients"
@attribute [Authorize]
@using DashboardApp.Services
@using Dashboard.Shared.DTOs
@inject IClientService ClientService
@inject IInvoiceService InvoiceService
@inject ToastService ToastService

<PageTitle>Customer Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Customers</h1>
            <p class="text-muted small mb-0">Manage your business relationships and contact details.</p>
        </div>
        <button class="btn btn-primary shadow-sm rounded-pill px-4" @onclick="ShowAddModal">
            <i class="bi bi-person-plus-fill me-2"></i> Add New Client
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="input-group filter-bar shadow-sm rounded-pill overflow-hidden bg-white border">
                <span class="input-group-text bg-transparent border-0 ps-3"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-0 bg-transparent" placeholder="Search by name, email or Tax ID..." @bind="searchTerm" @bind:event="oninput" />
            </div>
        </div>
    </div>


    @if (clients == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var client in FilteredClients)
            {

                <div class="col">
                    <div class="card border-0 shadow-sm rounded-4 h-100 id-card overflow-hidden">
                        <div class="card-body p-0">
                            <div class="id-card-header d-flex justify-content-between align-items-center p-3 text-white">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-box me-3 shadow-sm">
                                        <span class="fw-bold">
                                            @((!string.IsNullOrEmpty(client.Nom) ? client.Nom[0].ToString() : "") + 
                                              (!string.IsNullOrEmpty(client.Prenom) ? client.Prenom[0].ToString() : ""))
                                        </span>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-uppercase letter-spacing-1">Factun Partner</h6>
                                        <span class="x-small opacity-75">ID: #@client.Id.ToString("D4")</span>
                                    </div>
                                </div>
                                <div class="dropdown">
                                    <button class="btn btn-link text-white p-0 opacity-75 hover-opacity-100" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2">
                                        <li><button class="dropdown-item py-2" @onclick="() => ShowEditModal(client)"><i class="bi bi-pencil-square me-2 text-primary"></i> Edit Client</button></li>
                                        <li><button class="dropdown-item py-2 text-danger" @onclick="() => ConfirmDelete(client)"><i class="bi bi-trash3 me-2"></i> Delete Client</button></li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="p-4">
                                <div class="mb-3">
                                    <label class="id-label">Full Name</label>
                                    <div class="id-value fw-bold fs-5">@client.Prenom @client.Nom</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label class="id-label">Tax ID (MF)</label>
                                    <div class="id-value font-monospace">@client.MatriculeFiscal</div>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <label class="id-label">Phone</label>
                                        <div class="id-value small text-truncate">@client.Telephone</div>
                                    </div>
                                    <div class="col-6">
                                        <label class="id-label">Email</label>
                                        <div class="id-value small text-truncate">@client.Email</div>
                                    </div>
                                </div>

                                <div class="mb-0">
                                    <label class="id-label">Registered Office</label>
                                    <div class="id-value small text-truncate">@client.Adresse</div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-0 py-3 px-4 d-flex justify-content-between align-items-center">
                            <span class="x-small text-muted">Valid Since: @client.DateCreation.ToShortDateString()</span>
                            <button class="btn btn-sm btn-green-outline rounded-pill px-3 fw-bold" @onclick="() => ShowHistory(client)">
                                <i class="bi bi-clock-history me-1"></i> History
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showHistoryModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4 p-2">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Invoice History</h5>
                    <button type="button" class="btn-close" @onclick="() => showHistoryModal = false"></button>
                </div>
                <div class="modal-body pt-3">
                    <p class="text-muted small mb-3">Recent invoices for <strong>@selectedClient?.Prenom @selectedClient?.Nom</strong></p>
                    @if (clientInvoices == null)
                    {
                        <p class="text-center py-3 text-muted">Loading history...</p>
                    }
                    else if (!clientInvoices.Any())
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-folder2-open fs-2 text-muted opacity-50"></i>
                            <p class="text-muted mt-2">No invoices found for this client.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var inv in clientInvoices)
                            {
                                <div class="list-group-item px-0 border-0 d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold">@inv.Numero</div>
                                        <div class="x-small text-muted">@inv.DateFacture.ToShortDateString()</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-bold">@inv.TotalTTC.ToString("N3") TND</div>
                                        <span class="badge rounded-pill bg-light text-dark x-small">@inv.Statut</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <button class="btn btn-light rounded-pill w-100 mt-4 fw-bold" @onclick="() => showHistoryModal = false">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4 p-2">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">@(currentClient.Id == 0 ? "New Client" : "Edit Client")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body pt-3">
                    <EditForm Model="currentClient" OnValidSubmit="SaveClient">
                        <DataAnnotationsValidator />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">First Name</label>
                                <InputText @bind-Value="currentClient.Prenom" class="form-control rounded-3" placeholder="Sami" />
                                <ValidationMessage For="@(() => currentClient.Prenom)" class="text-danger small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Last Name</label>
                                <InputText @bind-Value="currentClient.Nom" class="form-control rounded-3" placeholder="Trabelsi" />
                                <ValidationMessage For="@(() => currentClient.Nom)" class="text-danger small" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Tax ID (Matricule Fiscal)</label>
                            <InputText @bind-Value="currentClient.MatriculeFiscal" class="form-control rounded-3" placeholder="13 digits/chars" />
                            <ValidationMessage For="@(() => currentClient.MatriculeFiscal)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email Address</label>
                            <InputText @bind-Value="currentClient.Email" class="form-control rounded-3" placeholder="client@example.com" />
                            <ValidationMessage For="@(() => currentClient.Email)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Phone Number</label>
                            <InputText @bind-Value="currentClient.Telephone" class="form-control rounded-3" placeholder="+216 ..." />
                            <ValidationMessage For="@(() => currentClient.Telephone)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Address</label>
                            <InputTextArea @bind-Value="currentClient.Adresse" class="form-control rounded-3" rows="2" placeholder="Full address..." />
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="button" class="btn btn-light rounded-pill px-4 flex-grow-1" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 flex-grow-1">Save Client</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4 p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                </div>
                <h4 class="fw-bold">Delete Client?</h4>
                <p class="text-muted">Are you sure you want to delete <strong>@clientToDelete?.Prenom @clientToDelete?.Nom</strong>? This action cannot be undone.</p>
                <div class="mt-4 d-flex gap-2">
                    <button type="button" class="btn btn-light rounded-pill px-4 flex-grow-1" @onclick="() => showDeleteConfirm = false">Cancel</button>
                    <button type="button" class="btn btn-danger rounded-pill px-4 flex-grow-1" @onclick="ExecuteDelete">Delete Anyway</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .id-card { 
        transition: transform 0.2s, box-shadow 0.2s; 
        border-radius: 20px !important;
        background: #ffffff;
    }
    .id-card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .id-card-header {
        background: #111111;
        border-bottom: 3px solid #249863;
    }
    .avatar-box {
        width: 48px;
        height: 48px;
        background: #249863;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
    }
    .id-label {
        font-size: 0.65rem;
        text-uppercase;
        font-weight: 700;
        color: #999;
        margin-bottom: 2px;
        display: block;
        letter-spacing: 0.5px;
    }
    .id-value {
        color: #333;
    }
    .letter-spacing-1 { letter-spacing: 1px; }
    .x-small { font-size: 0.75rem; }
    .btn-green-outline {
        color: #249863;
        border: 1px solid rgba(36, 152, 99, 0.3);
        background: rgba(36, 152, 99, 0.05);
        transition: all 0.2s;
    }
    .btn-green-outline:hover {
        background: #249863;
        color: white;
    }

    .filter-bar {
        max-width: 450px;
        transition: all 0.2s;
    }
    .filter-bar:focus-within {
        border-color: #249863 !important;
        box-shadow: 0 0 0 0.25rem rgba(36, 152, 99, 0.1) !important;
    }
</style>


@code {
    private List<ClientDto>? clients;
    private string searchTerm = "";
    private IEnumerable<ClientDto> FilteredClients => 
        clients?.Where(c => string.IsNullOrWhiteSpace(searchTerm) || 
            (c.Nom?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) || 
            (c.Prenom?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) || 
            (c.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) || 
            (c.MatriculeFiscal?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) 
        ?? Enumerable.Empty<ClientDto>();

    private bool showModal = false;

    private bool showHistoryModal = false;
    private ClientDto currentClient = new();
    private ClientDto? selectedClient;
    private ClientDto? clientToDelete;
    private List<InvoiceDto>? clientInvoices;
    private bool showDeleteConfirm = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadClients();
    }

    private async Task LoadClients()
    {
        clients = await ClientService.GetAllAsync();
    }

    private async Task ShowHistory(ClientDto client)
    {
        selectedClient = client;
        showHistoryModal = true;
        clientInvoices = null; // Loading state
        
        var allInvoices = await InvoiceService.GetAllAsync();
        clientInvoices = allInvoices.Where(i => i.ClientId == client.Id).OrderByDescending(i => i.DateFacture).ToList();
    }

    private void ShowAddModal()
    {
        currentClient = new ClientDto();
        showModal = true;
    }

    private void ShowEditModal(ClientDto client)
    {
        currentClient = new ClientDto
        {
            Id = client.Id,
            Nom = client.Nom,
            Prenom = client.Prenom,
            Email = client.Email,
            Telephone = client.Telephone,
            Adresse = client.Adresse,
            MatriculeFiscal = client.MatriculeFiscal,
            DateCreation = client.DateCreation
        };
        showModal = true;
    }

    private async Task SaveClient()
    {
        bool success;
        string action = currentClient.Id == 0 ? "created" : "updated";
        
        if (currentClient.Id == 0)
            success = await ClientService.CreateAsync(currentClient);
        else
            success = await ClientService.UpdateAsync(currentClient);

        if (success)
        {
            ToastService.ShowSuccess($"Client successfully {action}.");
            showModal = false;
            await LoadClients();
        }
        else
        {
            ToastService.ShowError($"Failed to {action} client.");
        }
    }

    private void ConfirmDelete(ClientDto client)
    {
        clientToDelete = client;
        showDeleteConfirm = true;
    }

    private async Task ExecuteDelete()
    {
        if (clientToDelete == null) return;
        
        var success = await ClientService.DeleteAsync(clientToDelete.Id);
        showDeleteConfirm = false;
        
        if (success) 
        {
            ToastService.ShowSuccess("Client deleted successfully.");
            await LoadClients();
        }
        else
        {
            ToastService.ShowError("Failed to delete client.");
        }
    }

    private void CloseModal() => showModal = false;
}
