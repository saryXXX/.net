@page "/stock"
@attribute [Authorize]
@using DashboardApp.Services
@using Dashboard.Shared.DTOs
@inject IProductService ProductService

<PageTitle>Stock Intelligence</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Stock Inventory</h1>
            <p class="text-muted small mb-0">Real-time stock levels and replenishment alerts.</p>
        </div>
        <div class="d-flex gap-2">
            <div class="card border-0 shadow-sm px-3 py-2 d-flex flex-row align-items-center bg-white rounded-3">
                <div class="text-danger me-2"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div>
                    <div class="fw-bold text-danger line-height-1">@products?.Count(p => p.StockActuel <= p.SeuilAlerte)</div>
                    <div class="x-small text-muted">Alerts</div>
                </div>
            </div>
        </div>
    </div>

    @if (products == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <h6 class="text-uppercase small fw-bold text-muted mb-3">Inventory Health</h6>
                    <div class="progress mb-2" style="height: 10px; border-radius: 5px;">
                        @{
                            var healthyCount = products.Count(p => p.StockActuel > p.SeuilAlerte);
                            var lowCount = products.Count(p => p.StockActuel > 0 && p.StockActuel <= p.SeuilAlerte);
                            var outCount = products.Count(p => p.StockActuel <= 0);
                            var total = products.Count;
                        }
                        <div class="progress-bar bg-success" role="progressbar" style="width: @(total > 0 ? (healthyCount * 100 / total) : 0)%" aria-valuenow="70" aria-valuemin="0" aria-valuemax="100"></div>
                        <div class="progress-bar bg-warning" role="progressbar" style="width: @(total > 0 ? (lowCount * 100 / total) : 0)%" aria-valuenow="20" aria-valuemin="0" aria-valuemax="100"></div>
                        <div class="progress-bar bg-danger" role="progressbar" style="width: @(total > 0 ? (outCount * 100 / total) : 0)%" aria-valuenow="10" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="d-flex justify-content-between small text-muted">
                        <span>Healthy (@healthyCount)</span>
                        <span>Low (@lowCount)</span>
                        <span>Out (@outCount)</span>
                    </div>
                </div>
            </div>
            
            <div class="col-md-8">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="text-uppercase small fw-bold text-muted mb-0">Critical Items</h6>
                        <span class="badge bg-danger-subtle text-danger rounded-pill px-2 small">Action Required</span>
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var prod in products.Where(p => p.StockActuel <= p.SeuilAlerte).Take(3))
                        {
                            <div class="list-group-item px-0 border-0 d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="icon-sm rounded-circle bg-light text-danger me-2"><i class="bi bi-box"></i></div>
                                    <span class="fw-medium">@prod.Nom</span>
                                </div>
                                <span class="fw-bold text-danger">@prod.StockActuel / @prod.SeuilAlerte</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Full Inventory Status</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="bg-light">
                                <th class="ps-4 py-3">Product</th>
                                <th class="py-3 text-center">Current Stock</th>
                                <th class="py-3 text-center">Alert Seuil</th>
                                <th class="py-3">Stock Level</th>
                                <th class="pe-4 text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prod in products)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@prod.Nom</div>
                                        <div class="text-muted x-small">Ref: P-@prod.Id</div>
                                    </td>
                                    <td class="text-center fw-bold">@prod.StockActuel</td>
                                    <td class="text-center text-muted">@prod.SeuilAlerte</td>
                                    <td style="width: 300px;">
                                        @{
                                            var percent = prod.StockActuel > prod.SeuilAlerte * 2 ? 100 : (prod.StockActuel * 100 / (prod.SeuilAlerte * 2 == 0 ? 1 : prod.SeuilAlerte * 2));
                                            var color = prod.StockActuel <= 0 ? "bg-danger" : (prod.StockActuel <= prod.SeuilAlerte ? "bg-warning" : "bg-success");
                                        }
                                        <div class="progress" style="height: 6px; border-radius: 3px;">
                                            <div class="progress-bar @color" role="progressbar" style="width: @percent%"></div>
                                        </div>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3" @onclick="() => ShowAdjustModal(prod)">Update</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showAdjustModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow rounded-4 p-2">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Adjust Stock</h5>
                    <button type="button" class="btn-close" @onclick="() => showAdjustModal = false"></button>
                </div>
                <div class="modal-body pt-3">
                    <p class="text-muted small mb-3">Updating stock for <strong>@selectedProduct?.Nom</strong></p>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Current Quantity</label>
                        <input type="number" class="form-control rounded-3" @bind="newStock" />
                    </div>
                    <button class="btn btn-primary rounded-pill w-100 fw-bold" @onclick="SaveStockAdjustment">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .line-height-1 { line-height: 1; }
    .x-small { font-size: 0.75rem; }
    .icon-sm { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; }
    .bg-danger-subtle { background-color: #fee2e2; }
</style>

@inject ToastService ToastService

@code {
    private List<ProduitDto>? products;
    private bool showAdjustModal = false;
    private ProduitDto? selectedProduct;
    private int newStock;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        products = await ProductService.GetAllAsync();
    }

    private void ShowAdjustModal(ProduitDto prod)
    {
        selectedProduct = prod;
        newStock = prod.StockActuel;
        showAdjustModal = true;
    }

    private async Task SaveStockAdjustment()
    {
        if (selectedProduct == null) return;

        selectedProduct.StockActuel = newStock;
        var success = await ProductService.UpdateAsync(selectedProduct);
        
        if (success)
        {
            ToastService.ShowSuccess($"Stock updated for {selectedProduct.Nom}");
            showAdjustModal = false;
            await LoadProducts();
        }
        else
        {
            ToastService.ShowError("Failed to update stock.");
        }
    }
}
