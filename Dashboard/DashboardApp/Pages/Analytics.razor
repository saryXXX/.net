@page "/analytics"
@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Analytics Dashboard</PageTitle>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 15px;
        transition: transform 0.2s;
    }
    .glass-card:hover {
        transform: translateY(-5px);
    }
    .kpi-title {
        color: #6c757d;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }
</style>

<div class="container-fluid py-4">
    <h1 class="mb-4 text-primary">Analytics & Intelligence</h1>

    @if (stats == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <!-- KPI Cards -->
            <div class="col-md-3">
                <div class="card glass-card shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="kpi-title text-uppercase">Total Revenue (CA)</h6>
                        <h3 class="fw-bold">@stats.TotalCA.ToString("N3") <small class="fs-6">TND</small></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card glass-card shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="kpi-title text-uppercase">VAT Collected (TVA)</h6>
                        <h3 class="fw-bold text-success">@stats.TotalTVA.ToString("N3") <small class="fs-6">TND</small></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card glass-card shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="kpi-title text-uppercase">Active Invoices</h6>
                        <h3 class="fw-bold text-primary">@stats.TotalFactures</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card glass-card shadow-sm border-0">
                    <div class="card-body">
                        <h6 class="kpi-title text-uppercase">Stock Alerts</h6>
                        <h3 class="fw-bold text-danger">@stats.ProduitsEnAlerte</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Chart 1: CA per Period -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0">Revenue Evolution (CA)</h5>
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="ChartDataDto" Title="Monthly Turnover" XAxisType="XAxisType.Category">
                            <ApexPointSeries TItem="ChartDataDto" 
                                           Items="stats.TurnoverHistory" 
                                           Name="Revenue" 
                                           SeriesType="SeriesType.Area"
                                           XValue="@(e => e.Label)" 
                                           YValue="@(e => e.Value)" 
                                           Color="#007bff" />
                        </ApexChart>
                    </div>
                </div>
            </div>

            <!-- Chart 2: TVA Breakdown -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0">VAT by Rate</h5>
                    </div>
                    <div class="card-body d-flex align-items-center">
                        @if (fiscalSummary?.TvaDetails?.Any() == true)
                        {
                            <ApexChart TItem="TvaRateDto" Title="TVA Distribution">
                                <ApexPointSeries TItem="TvaRateDto" 
                                                Items="fiscalSummary.TvaDetails" 
                                                Name="VAT Amount" 
                                                SeriesType="SeriesType.Donut" 
                                                XValue="@(e => $"{e.Rate}%")" 
                                                YValue="@(e => e.TotalTva)" />
                            </ApexChart>
                        }
                        else
                        {
                            <p class="text-center w-100 text-muted italic">No TVA data available</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Chart 3: Stock Status -->
            <div class="col-lg-6">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0">Inventory Health</h5>
                    </div>
                    <div class="card-body">
                        @if (inventorySummary?.StatusBreakdown?.Any() == true)
                        {
                            <ApexChart TItem="StockStatusDto" Title="Stock Breakdown">
                                <ApexPointSeries TItem="StockStatusDto" 
                                                Items="inventorySummary.StatusBreakdown" 
                                                Name="Product Count" 
                                                SeriesType="SeriesType.Bar" 
                                                XValue="@(e => e.Status)" 
                                                YValue="@(e => (decimal)e.Count)"
                                                Color="#ffc107" />
                            </ApexChart>
                        }
                    </div>
                </div>
            </div>

            <!-- Chart 4: Top Products -->
            <div class="col-lg-6">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0">Top 5 Products (by Revenue)</h5>
                    </div>
                    <div class="card-body">
                        <ApexChart TItem="TopProductDto" Title="Top Performance">
                            <ApexPointSeries TItem="TopProductDto" 
                                            Items="stats.TopProducts" 
                                            Name="Revenue" 
                                            SeriesType="SeriesType.Bar" 
                                            XValue="@(e => e.ProductName)" 
                                            YValue="@(e => e.TotalRevenue)"
                                            Color="#28a745" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardStatsDto? stats;
    private FiscalSummaryDto? fiscalSummary;
    private InventorySummaryDto? inventorySummary;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fetch all data in parallel
            var statsTask = Http.GetFromJsonAsync<DashboardStatsDto>("api/analytics/dashboard");
            var fiscalTask = Http.GetFromJsonAsync<FiscalSummaryDto>("api/analytics/fiscal");
            var inventoryTask = Http.GetFromJsonAsync<InventorySummaryDto>("api/analytics/inventory");

            await Task.WhenAll(statsTask, fiscalTask, inventoryTask);

            stats = await statsTask;
            fiscalSummary = await fiscalTask;
            inventorySummary = await inventoryTask;

            // Data Resiliency: Ensure charts don't break if no data is found
            if (stats != null && (stats.TurnoverHistory == null || !stats.TurnoverHistory.Any()))
            {
                stats.TurnoverHistory = new List<ChartDataDto> { new() { Label = "No Data", Value = 0 } };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching data: {ex.Message}");
            // Initialize with defaults to prevent UI crash
            stats = new DashboardStatsDto();
            fiscalSummary = new FiscalSummaryDto();
            inventorySummary = new InventorySummaryDto();
        }
    }
}
