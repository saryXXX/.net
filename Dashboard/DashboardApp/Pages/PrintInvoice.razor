@page "/invoices/print/{Id:int}"
@using DashboardApp.Services
@using Dashboard.Shared.DTOs
@using Net.Codecrete.QrCodeGenerator
@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@layout Layout.EmptyLayout

@if (invoice == null)
{
    <div class="d-flex justify-content-center py-5 no-print">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="invoice-container bg-white p-5 mx-auto my-3 shadow-sm" id="printable-invoice">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-4">
            <div>
                <img src="logo.png" alt="Sary Logo" style="height: 140px; object-fit: contain; margin-bottom: 15px;" />
                <div class="mt-2" style="line-height: 1.3;">
                    <p class="mb-0 fw-bold text-dark small text-uppercase" style="letter-spacing: 1px;">Vendeur:</p>
                    <p class="mb-0 fw-bold h5 text-dark">MA SOCIETE SARL</p>
                    <p class="mb-0 x-small text-muted">123 Rue de la Liberté, Tunis</p>
                    <p class="mb-0 x-small text-muted">Matricule: 1234567/A/M/000</p>
                </div>
            </div>
            <div class="text-end">
                <h1 class="fw-black mb-0" style="color: #198754; font-size: 3.5rem; letter-spacing: -2px;">FACTURE</h1>
                <p class="text-dark fw-bold mb-3 h5">N° @invoice.Numero</p>
                <div class="qr-code-container mb-2 d-inline-block p-1 border rounded bg-white">
                    <div style="width: 120px; height: 120px;">
                        @((MarkupString)qrCodeSvg)
                    </div>
                </div>
                <div class="mt-1">
                    <p class="mb-0 fw-bold x-small text-uppercase text-muted">Date d'émission</p>
                    <p class="fw-bold h6">@invoice.DateFacture.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Client Info -->
        <div class="row mb-5">
            <div class="col-6">
                <div class="p-4 border-start border-4 border-success bg-light rounded-end shadow-sm">
                    <h6 class="text-uppercase text-muted fw-bold mb-2 x-small" style="letter-spacing: 1px;">Facturé à:</h6>
                    <h5 class="fw-bold mb-1 text-dark">@invoice.ClientName</h5>
                    <p class="mb-0 x-small text-muted">@invoice.ClientMatricule</p>
                </div>
            </div>
            <div class="col-6 text-end">
                <div class="d-inline-block text-start p-3 border rounded bg-white shadow-sm">
                    <h6 class="text-uppercase text-muted fw-bold mb-1 x-small text-center border-bottom pb-1">Statut</h6>
                    <span class="badge @(invoice.Statut == "Payée" ? "bg-success" : "bg-dark") w-100 px-3 py-2 rounded-2 mt-1">
                        @invoice.Statut.ToUpper()
                    </span>
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <div class="table-responsive mb-5">
            <table class="table table-borderless align-middle mb-0">
                <thead>
                    <tr class="text-white" style="background-color: #1a1a1a;">
                        <th class="py-3 ps-3 rounded-start">DESCRIPTION</th>
                        <th class="py-3 text-center">QTÉ</th>
                        <th class="py-3 text-end">PU HT</th>
                        <th class="py-3 text-center">TVA</th>
                        <th class="py-3 text-end pe-3 rounded-end">TOTAL HT</th>
                    </tr>
                </thead>
                <tbody class="x-small">
                    @{ int i = 0; }
                    @foreach (var l in invoice.Lignes)
                    {
                        <tr class="@(i++ % 2 == 0 ? "bg-light" : "")">
                            <td class="py-3 ps-3 fw-medium">@l.ProductName</td>
                            <td class="py-3 text-center">@l.Quantite</td>
                            <td class="py-3 text-end">@l.PrixUnitaireHT.ToString("N3")</td>
                            <td class="py-3 text-center">@l.TauxTVA %</td>
                            <td class="py-3 text-end pe-3 fw-bold">@l.MontantHT.ToString("N3")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Totals -->
        <div class="row justify-content-end mb-5">
            <div class="col-5">
                <div class="p-4 border rounded bg-white shadow-sm">
                    <div class="d-flex justify-content-between mb-2 x-small">
                        <span class="text-muted">Total Net HT</span>
                        <span class="fw-bold text-dark">@invoice.TotalHT.ToString("N3")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 x-small">
                        <span class="text-muted">Total TVA</span>
                        <span class="fw-bold text-dark">@invoice.TotalTVA.ToString("N3")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 border-bottom pb-2 x-small">
                        <span class="text-muted">Droit de Timbre</span>
                        <span class="fw-bold text-dark">@invoice.TimbreFiscal.ToString("N3")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-black text-dark h5 mb-0">TOTAL TTC</span>
                        <span class="fw-black h4 mb-0" style="color: #198754;">@invoice.TotalTTC.ToString("N3") <small>TND</small></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toolbar for Screen only -->
        <div class="text-center mb-5 no-print">
            <button class="btn btn-lg btn-primary rounded-pill px-5 shadow" @onclick="Print">
                <i class="bi bi-printer me-2"></i> Imprimer la Facture
            </button>
            <button class="btn btn-lg btn-outline-secondary rounded-pill px-5 ms-3 shadow-sm" @onclick='() => Navigation.NavigateTo("/invoices")'>
                <i class="bi bi-arrow-left me-2"></i> Retour
            </button>
        </div>

        <!-- Footer -->
        <div class="mt-5 pt-4 border-top text-center x-small">
            <p class="mb-1 fw-bold text-dark">TECHNOCODE SOLUTIONS - Excellence en Gestion de Stock</p>
            <p class="mb-0 text-muted">Capital: 10,000 TND | RC: B1234562024 | Matricule Fiscal: 1234567/A/M/000</p>
            <p class="mt-2 text-success fw-bold">Merci pour votre confiance!</p>
        </div>
    </div>
}

<style>
    .invoice-container {
        max-width: 900px;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    .fw-black { font-weight: 900; }
    @@media print {
        @@page { size: portrait; margin: 15mm; }
        .no-print { display: none !important; }
        body { background-color: white !important; -webkit-print-color-adjust: exact; }
        .invoice-container { 
            box-shadow: none !important; 
            margin: 0 !important; 
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            border: none !important;
        }
        .table thead tr { background-color: #1a1a1a !important; -webkit-print-color-adjust: exact; }
        .bg-light { background-color: #f8f9fa !important; -webkit-print-color-adjust: exact; }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private InvoiceDto? invoice;
    private string qrCodeSvg = "";

    protected override async Task OnInitializedAsync()
    {
        invoice = await InvoiceService.GetByIdAsync(Id);
        if (invoice != null)
        {
            GenerateQRCode();
        }
    }

    private void GenerateQRCode()
    {
        var content = $"INV:{invoice?.Numero ?? ""}|DATE:{invoice?.DateFacture:yyyy-MM-dd}|CLIENT:{invoice?.ClientMatricule ?? ""}|TTC:{invoice?.TotalTTC ?? 0}";
        var qrCode = QrCode.EncodeText(content, QrCode.Ecc.High);
        qrCodeSvg = qrCode.ToSvgString(4);
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task Print()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}
