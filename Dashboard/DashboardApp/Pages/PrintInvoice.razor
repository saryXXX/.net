@page "/invoices/print/{Id:int}"
@using DashboardApp.Services
@using Dashboard.Shared.DTOs
@using Net.Codecrete.QrCodeGenerator
@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@layout Layout.EmptyLayout

@if (invoice == null)
{
    <div class="d-flex justify-content-center py-5 no-print">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="invoice-container bg-white p-5 mx-auto my-4 shadow-sm" id="printable-invoice">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <h1 class="display-6 fw-bold text-primary mb-0">FACTURE</h1>
                <p class="text-muted h5">N° @invoice.Numero</p>
                <div class="mt-3">
                    <p class="mb-0 fw-bold text-dark">Vendeur:</p>
                    <p class="mb-0">MA SOCIETE SARL</p>
                    <p class="mb-0">123 Rue de la Liberté, Tunis</p>
                    <p class="mb-0">Matricule: 1234567/A/M/000</p>
                </div>
            </div>
            <div class="text-end">
                <div class="qr-code-container mb-3 d-inline-block">
                    <div style="width: 120px; height: 120px;">
                        @((MarkupString)qrCodeSvg)
                    </div>
                    <p class="small text-muted mt-1 mb-0">E-Facture QR</p>
                </div>
                <div class="mt-2">
                    <p class="mb-0 fw-bold">Date d'émission:</p>
                    <p>@invoice.DateFacture.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Client Info -->
        <div class="row mb-5">
            <div class="col-6">
                <div class="p-3 border rounded shadow-sm bg-light">
                    <h6 class="text-uppercase text-muted fw-bold mb-3 small">Facturé à:</h6>
                    <h5 class="fw-bold mb-1">@invoice.ClientName</h5>
                    <p class="mb-0">@invoice.ClientMatricule</p>
                    <p class="mb-0 text-muted">Client ID: #@invoice.ClientId</p>
                </div>
            </div>
            <div class="col-6 text-end d-flex flex-column justify-content-center">
                <h6 class="text-uppercase text-muted fw-bold mb-2 small">Statut de Paiement:</h6>
                <div>
                    <span class="badge @(invoice.Statut == "Payée" ? "bg-success" : "bg-warning text-dark") px-3 py-2 rounded-pill">
                        @invoice.Statut
                    </span>
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <div class="table-responsive mb-5">
            <table class="table table-bordered align-middle">
                <thead class="bg-primary text-white">
                    <tr>
                        <th class="py-3">Description</th>
                        <th class="py-3 text-center">Qté</th>
                        <th class="py-3 text-end">PU HT</th>
                        <th class="py-3 text-center">TVA</th>
                        <th class="py-3 text-end">Total HT</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in invoice.Lignes)
                    {
                        <tr>
                            <td class="py-3">@l.ProductName</td>
                            <td class="text-center">@l.Quantite</td>
                            <td class="text-end">@l.PrixUnitaireHT.ToString("N3")</td>
                            <td class="text-center">@l.TauxTVA %</td>
                            <td class="text-end fw-bold">@l.MontantHT.ToString("N3")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Totals -->
        <div class="row justify-content-end">
            <div class="col-5">
                <table class="table table-sm table-borderless">
                    <tr>
                        <td class="text-muted">Total Hors Taxe</td>
                        <td class="text-end fw-bold">@invoice.TotalHT.ToString("N3") TND</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Total TVA</td>
                        <td class="text-end fw-bold">@invoice.TotalTVA.ToString("N3") TND</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Droit de Timbre</td>
                        <td class="text-end fw-bold">@invoice.TimbreFiscal.ToString("N3") TND</td>
                    </tr>
                    <tr class="border-top" style="border-width: 2px !important;">
                        <td class="h4 fw-bold text-primary">TOTAL TTC</td>
                        <td class="h4 fw-bold text-primary text-end">@invoice.TotalTTC.ToString("N3") TND</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Footer -->
        <div class="mt-5 pt-5 border-top text-center text-muted small">
            <p class="mb-1 fw-bold text-dark">Informations Légales</p>
            <p class="mb-0">Capital: 10,000 TND | RC: B1234562024 | CNSS: 123456-78</p>
            <p>Merci pour votre confiance!</p>
        </div>
    </div>

    <!-- Toolbar for Screen only -->
    <div class="text-center mb-5 no-print">
        <button class="btn btn-lg btn-primary rounded-pill px-5 shadow" @onclick="Print">
            <i class="bi bi-printer me-2"></i> Imprimer la Facture
        </button>
        <button class="btn btn-lg btn-outline-secondary rounded-pill px-5 ms-3 shadow-sm" @onclick='() => Navigation.NavigateTo("/invoices")'>
            <i class="bi bi-arrow-left me-2"></i> Retour
        </button>
    </div>
}

<style>
    .invoice-container {
        max-width: 900px;
        min-height: 1100px;
    }
    @@media print {
        .no-print { display: none !important; }
        body { background-color: white !important; }
        .invoice-container { 
            box-shadow: none !important; 
            margin: 0 !important; 
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
        }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private InvoiceDto? invoice;
    private string qrCodeSvg = "";

    protected override async Task OnInitializedAsync()
    {
        invoice = await InvoiceService.GetByIdAsync(Id);
        if (invoice != null)
        {
            GenerateQRCode();
        }
    }

    private void GenerateQRCode()
    {
        var content = $"INV:{invoice?.Numero ?? ""}|DATE:{invoice?.DateFacture:yyyy-MM-dd}|CLIENT:{invoice?.ClientMatricule ?? ""}|TTC:{invoice?.TotalTTC ?? 0}";
        var qrCode = QrCode.EncodeText(content, QrCode.Ecc.High);
        qrCodeSvg = qrCode.ToSvgString(4);
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task Print()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}
