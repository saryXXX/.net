@page "/invoices/print/{Id:int}"
@using DashboardApp.Services
@using Dashboard.Shared.DTOs
@using Net.Codecrete.QrCodeGenerator
@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@layout Layout.EmptyLayout

@if (invoice == null)
{
    <div class="d-flex justify-content-center py-5 no-print">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="invoice-container bg-white p-4 mx-auto my-3 shadow-sm" id="printable-invoice">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <img src="logo.png" alt="Sary Logo" style="height: 90px; object-fit: contain; margin-bottom: 10px;" />
                <h2 class="fw-bold text-primary mb-0">FACTURE</h2>
                <p class="text-muted mb-0">N° @invoice.Numero</p>
                <div class="mt-2" style="line-height: 1.2;">
                    <p class="mb-0 fw-bold text-dark x-small">Vendeur:</p>
                    <p class="mb-0 x-small">MA SOCIETE SARL</p>
                    <p class="mb-0 x-small">123 Rue de la Liberté, Tunis</p>
                    <p class="mb-0 x-small">Matricule: 1234567/A/M/000</p>
                </div>
            </div>
            <div class="text-end">
                <div class="qr-code-container mb-2 d-inline-block">
                    <div style="width: 110px; height: 110px;">
                        @((MarkupString)qrCodeSvg)
                    </div>
                </div>
                <div class="mt-1">
                    <p class="mb-0 fw-bold x-small">Date:</p>
                    <p class="x-small">@invoice.DateFacture.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Client Info -->
        <div class="row mb-2">
            <div class="col-6">
                <div class="p-2 border rounded bg-white">
                    <h6 class="text-uppercase text-muted fw-bold mb-1 x-small">Facturé à:</h6>
                    <h5 class="fw-bold mb-1">@invoice.ClientName</h5>
                    <p class="mb-0 x-small">@invoice.ClientMatricule</p>
                </div>
            </div>
            <div class="col-6 text-end d-flex flex-column justify-content-center">
                <div>
                    <span class="badge @(invoice.Statut == "Payée" ? "bg-success" : "bg-warning text-dark") px-2 py-1 x-small rounded-pill">
                        @invoice.Statut
                    </span>
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <div class="table-responsive mb-2">
            <table class="table table-bordered align-middle mb-0">
                <thead class="bg-primary text-white x-small">
                    <tr>
                        <th class="py-1">Description</th>
                        <th class="py-1 text-center">Qté</th>
                        <th class="py-1 text-end">PU HT</th>
                        <th class="py-1 text-center">TVA</th>
                        <th class="py-1 text-end">Total HT</th>
                    </tr>
                </thead>
                <tbody class="x-small">
                    @foreach (var l in invoice.Lignes)
                    {
                        <tr>
                            <td class="py-1">@l.ProductName</td>
                            <td class="py-1 text-center">@l.Quantite</td>
                            <td class="py-1 text-end">@l.PrixUnitaireHT.ToString("N3")</td>
                            <td class="py-1 text-center">@l.TauxTVA %</td>
                            <td class="py-1 text-end fw-bold">@l.MontantHT.ToString("N3")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Totals -->
        <div class="row justify-content-end mb-1">
            <div class="col-5">
                <table class="table table-sm table-borderless mb-0 x-small">
                    <tr>
                        <td class="text-muted py-0">Total HT</td>
                        <td class="text-end fw-bold py-0">@invoice.TotalHT.ToString("N3")</td>
                    </tr>
                    <tr>
                        <td class="text-muted py-0">Total TVA</td>
                        <td class="text-end fw-bold py-0">@invoice.TotalTVA.ToString("N3")</td>
                    </tr>
                    <tr>
                        <td class="text-muted py-0">Timbre</td>
                        <td class="text-end fw-bold py-0">@invoice.TimbreFiscal.ToString("N3")</td>
                    </tr>
                    <tr class="border-top">
                        <td class="fw-bold text-primary py-1" style="font-size: 1.1rem;">TOTAL TTC</td>
                        <td class="fw-bold text-primary text-end py-1" style="font-size: 1.1rem;">@invoice.TotalTTC.ToString("N3") TND</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Footer -->
        <div class="mt-2 pt-2 border-top text-center text-muted x-small">
            <p class="mb-0 fw-bold text-dark">Propulsion par Sary System - Capital: 10,000 TND | RC: B1234562024</p>
            <p class="mb-0">Merci pour votre confiance!</p>
        </div>
    </div>

    <!-- Toolbar for Screen only -->
    <div class="text-center mb-5 no-print">
        <button class="btn btn-lg btn-primary rounded-pill px-5 shadow" @onclick="Print">
            <i class="bi bi-printer me-2"></i> Imprimer la Facture
        </button>
        <button class="btn btn-lg btn-outline-secondary rounded-pill px-5 ms-3 shadow-sm" @onclick='() => Navigation.NavigateTo("/invoices")'>
            <i class="bi bi-arrow-left me-2"></i> Retour
        </button>
    </div>
}

<style>
    .invoice-container {
        max-width: 800px;
        font-size: 0.95rem;
    }
    @@media print {
        @@page { size: auto; margin: 5mm; }
        .no-print { display: none !important; }
        body { background-color: white !important; -webkit-print-color-adjust: exact; }
        .invoice-container { 
            box-shadow: none !important; 
            margin: 0 !important; 
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            border: none !important;
        }
        .table td, .table th { padding: 0.4rem !important; }
        .invoice-container { page-break-after: avoid; }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private InvoiceDto? invoice;
    private string qrCodeSvg = "";

    protected override async Task OnInitializedAsync()
    {
        invoice = await InvoiceService.GetByIdAsync(Id);
        if (invoice != null)
        {
            GenerateQRCode();
        }
    }

    private void GenerateQRCode()
    {
        var content = $"INV:{invoice?.Numero ?? ""}|DATE:{invoice?.DateFacture:yyyy-MM-dd}|CLIENT:{invoice?.ClientMatricule ?? ""}|TTC:{invoice?.TotalTTC ?? 0}";
        var qrCode = QrCode.EncodeText(content, QrCode.Ecc.High);
        qrCodeSvg = qrCode.ToSvgString(4);
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task Print()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}
