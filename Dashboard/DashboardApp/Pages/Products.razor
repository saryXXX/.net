@page "/products"
@attribute [Authorize]
@using DashboardApp.Services
@using Dashboard.Shared.DTOs
@inject IProductService ProductService
@inject ToastService ToastService


<PageTitle>Products Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Inventory & Products</h1>
            <p class="text-muted small mb-0">Manage your product catalog and stock levels.</p>
        </div>
        <button class="btn btn-brand-green shadow-sm rounded-pill px-4 fw-bold" @onclick="ShowAddModal">
            <i class="bi bi-plus-lg me-2"></i> Add New Product
        </button>

    </div>

    @if (products == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="brand-thead text-white">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase x-small fw-bold letter-spacing-1">Product Name</th>
                            <th class="py-3 text-uppercase x-small fw-bold letter-spacing-1 text-end">Price (HT)</th>
                            <th class="py-3 text-uppercase x-small fw-bold letter-spacing-1 text-center">VAT</th>
                            <th class="py-3 text-uppercase x-small fw-bold letter-spacing-1 text-center">Stock</th>
                            <th class="py-3 text-uppercase x-small fw-bold letter-spacing-1 text-center">Status</th>
                            <th class="pe-4 py-3 text-end text-uppercase x-small fw-bold letter-spacing-1">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var prod in products)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="product-icon-container me-3 shadow-sm">
                                            <i class="bi bi-box-fill brand-green-text"></i>
                                        </div>

                                        <div>
                                            <div class="fw-bold text-dark">@prod.Nom</div>
                                            <div class="text-muted x-small">ID: #@prod.Id.ToString("D4")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-end fw-medium">@prod.PrixUnitaireHT.ToString("N3") <small class="text-muted">TND</small></td>
                                <td class="text-center"><span class="badge bg-light text-dark border">@prod.TauxTVA%</span></td>
                                <td class="text-center">
                                    <div class="fw-bold @(prod.StockActuel <= prod.SeuilAlerte ? "text-danger" : "text-dark")">
                                        @prod.StockActuel
                                    </div>
                                    <div class="x-small text-muted">Min: @prod.SeuilAlerte</div>
                                </td>
                                <td class="text-center">
                                    @if (prod.StockActuel <= 0)
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger px-3">Out of Stock</span>
                                    }
                                    else if (prod.StockActuel <= prod.SeuilAlerte)
                                    {
                                        <span class="badge rounded-pill bg-warning-subtle text-warning px-3">Low Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success px-3">In Stock</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                        <button class="btn btn-white btn-sm px-3 border-end" title="Edit" @onclick="() => ShowEditModal(prod)">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </button>
                                        <button class="btn btn-white btn-sm px-3" title="Delete" @onclick="() => ConfirmDelete(prod)">
                                            <i class="bi bi-trash3-fill text-danger"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4 p-2">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">@(currentProduct.Id == 0 ? "Add Product" : "Edit Product")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="currentProduct" OnValidSubmit="SaveProduct">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Product Name</label>
                            <InputText @bind-Value="currentProduct.Nom" class="form-control rounded-3" placeholder="e.g. Wireless Mouse" />
                            <ValidationMessage For="@(() => currentProduct.Nom)" class="text-danger small" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Unit Price (HT)</label>
                                <div class="input-group">
                                    <InputNumber @bind-Value="currentProduct.PrixUnitaireHT" class="form-control rounded-3" />
                                    <span class="input-group-text bg-transparent border-start-0 text-muted small">TND</span>
                                </div>
                                <ValidationMessage For="@(() => currentProduct.PrixUnitaireHT)" class="text-danger small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">VAT Rate (%)</label>
                                <InputNumber @bind-Value="currentProduct.TauxTVA" class="form-control rounded-3" />
                                <ValidationMessage For="@(() => currentProduct.TauxTVA)" class="text-danger small" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Initial Stock</label>
                                <InputNumber @bind-Value="currentProduct.StockActuel" class="form-control rounded-3" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Alert Threshold</label>
                                <InputNumber @bind-Value="currentProduct.SeuilAlerte" class="form-control rounded-3" />
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="button" class="btn btn-light rounded-pill px-4 flex-grow-1" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 flex-grow-1">Save Product</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4 p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-exclamation-octagon text-danger" style="font-size: 3rem;"></i>
                </div>
                <h4 class="fw-bold">Remove Product?</h4>
                <p class="text-muted">Are you sure you want to remove <strong>@productToDelete?.Nom</strong> from the catalog? This cannot be undone.</p>
                <div class="mt-4 d-flex gap-2">
                    <button type="button" class="btn btn-light rounded-pill px-4 flex-grow-1" @onclick="() => showDeleteConfirm = false">Cancel</button>
                    <button type="button" class="btn btn-danger rounded-pill px-4 flex-grow-1 fw-bold" @onclick="ExecuteDelete">Delete Product</button>
                </div>
            </div>
        </div>
    </div>
}


<style>
    .product-icon-container {
        width: 42px;
        height: 42px;
        background: #111111;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }
    .brand-green-text { color: #249863; }
    .btn-brand-green {
        background-color: #249863;
        color: white;
        border: none;
        transition: all 0.2s;
    }
    .btn-brand-green:hover {
        background-color: #1e7e52;
        color: white;
        transform: translateY(-2px);
    }
    .brand-thead {
        background: #111111;
        border-bottom: 3px solid #249863;
    }
    .btn-white {
        background: white;
        border: 1px solid #f1f1f1;
    }
    .btn-white:hover {
        background: #f9f9f9;
        color: #249863;
    }
    .letter-spacing-1 { letter-spacing: 1px; }
    .x-small { font-size: 0.7rem; }
    .bg-danger-subtle { background-color: #fee2e2; color: #dc2626; }
    .bg-warning-subtle { background-color: #fef3c7; color: #d97706; }
    .bg-success-subtle { background-color: #dcfce7; color: #16a34a; }
</style>


@code {
    private List<ProduitDto>? products;
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private ProduitDto currentProduct = new();
    private ProduitDto? productToDelete;


    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        products = await ProductService.GetAllAsync();
    }

    private void ShowAddModal()
    {
        currentProduct = new ProduitDto();
        showModal = true;
    }

    private void ShowEditModal(ProduitDto prod)
    {
        // Clone the product to avoid direct mutation of the list before saving
        currentProduct = new ProduitDto
        {
            Id = prod.Id,
            Nom = prod.Nom,
            PrixUnitaireHT = prod.PrixUnitaireHT,
            TauxTVA = prod.TauxTVA,
            StockActuel = prod.StockActuel,
            SeuilAlerte = prod.SeuilAlerte,
            Actif = prod.Actif
        };
        showModal = true;
    }

    private async Task SaveProduct()
    {
        bool success;
        if (currentProduct.Id == 0)
            success = await ProductService.CreateAsync(currentProduct);
        else
            success = await ProductService.UpdateAsync(currentProduct);

        if (success)
        {
            ToastService.ShowSuccess($"Product successfully {(currentProduct.Id == 0 ? "created" : "updated")}.");
            showModal = false;
            await LoadProducts();
        }
        else
        {
            ToastService.ShowError("Failed to save product.");
        }
    }

    private void ConfirmDelete(ProduitDto prod)
    {
        productToDelete = prod;
        showDeleteConfirm = true;
    }

    private async Task ExecuteDelete()
    {
        if (productToDelete == null) return;
        
        var success = await ProductService.DeleteAsync(productToDelete.Id);
        showDeleteConfirm = false;
        
        if (success)
        {
            ToastService.ShowSuccess("Product deleted successfully.");
            await LoadProducts();
        }
        else
        {
            ToastService.ShowError("Failed to delete product.");
        }
    }


    private void CloseModal() => showModal = false;
}
